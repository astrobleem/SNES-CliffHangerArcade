
	SCRIPT title_screen
.ACCU 16
.INDEX 16

  .def objBackground hashPtr.1
  .def objText hashPtr.2
  .def objLogo hashPtr.3
  ;objBrightness is predefined at hashPtr.4 (hashPtr+12) in script.h
  ;objPlayer is predefined at hashPtr.5 (hashPtr+16) in script.h
  .def objLogoZoom hashPtr.6
  .def objSpc hashPtr.7
  .def objPalRotate hashPtr.8
  .def objSuper hashPtr.9
  ;--- Cleanup stale objects from previous session ---
  ;Stop HDMA hardware and flush DMA queue (prevents stale DMA on real SD2SNES)
  jsr core.dma.resetHardware

  lda.w #OBJECT.PROPERTIES.isSprite
  jsr abstract.Iterator.kill.byProperties

  lda.w #OBJECT.PROPERTIES.isHdma
  jsr abstract.Iterator.kill.byProperties

  jsr core.vram.init
  jsr core.cgram.clear

  lda.w #OBJECT.PROPERTIES.isChapter
  jsr abstract.Iterator.setProperties
  jsr abstract.Iterator.killOthers

  lda.w #OBJECT.PROPERTIES.isEvent
  jsr abstract.Iterator.kill.byProperties

  lda.w #OBJID.Msu1
  jsr abstract.Iterator.kill.byId

  stz.w GLOBAL.sceneRow
  stz.w GLOBAL.gameMode

  lda.w GLOBAL.credits
  bne _title_screen.hasCredits
    lda #1
    sta.w GLOBAL.credits
_title_screen.hasCredits:

  sep #$20
  lda.b #BGMODE_MODE_1 | BGMODE_PRIORITY_LAYER_3
  sta.w ScreenMode
  lda.w MainScreen
  and.b #(T_BG1_ENABLE | T_BG2_ENABLE | T_BG3_ENABLE | T_BG4_ENABLE) ~$ff

  sta.w MainScreen
  rep #$31

  NEW Brightness.CLS.PTR objBrightness
  NEW Background.generic.CLS.PTR objBackground BG.LAYER.1 BG.titlescreen.PTR

  lda #BRIGHTNESS.FULL
  CALL Brightness.fadeTo.MTD objBrightness

  NEW Background.generic.CLS.PTR objLogo BG.LAYER.0 BG.logo.PTR

  NEW LogoZoom.CLS.PTR objLogoZoom BG.LAYER.0

  ;try to reuse existing Spc (engine already uploaded by msu1)
  jsr abstract.Iterator.reset
  lda #OBJID.Spc
  jsr abstract.Iterator.each.byId
  bcc _title_screen.createSpc
    lda.b iterator.target
    sta.b objSpc
    lda.b iterator.target + 2
    sta.b objSpc + 2
    bra _title_screen.spcReady
_title_screen.createSpc:
  NEW Spc.CLS.PTR objSpc
_title_screen.spcReady:

  NEW Player.CLS.PTR objPlayer
  CALL Player.reset.MTD objPlayer

  lda.w GLOBAL.konamiActivated
  beq _title_screen.noKonami
    stz.w GLOBAL.konamiActivated
    lda #30
    sta.w GLOBAL.credits
_title_screen.noKonami:

  jsr core.irq.position.get
  stx irq.buffer.x
  sty irq.buffer.y

  ldy #213
  jsr core.irq.position.set

  jsr SavePC

  ;wait for logo zoomer to finish
  jsr abstract.Iterator.reset
-	lda #OBJID.LogoZoom
	jsr abstract.Iterator.each.byId
	bcc +
	  rts
+

  ;create text layer AFTER LogoZoom finishes — BG animations have settled
  ;(frame.current == frame.last), so no more competing palette DMA.
  NEW Background.textlayer.8x8.CLS.PTR objText

  CALL Background.generic.getAllocatedPalette.MTD objLogo
  bcc _title_screen.noPalRotate

  ;color index to start from, minus transparent color 0
  pea 0
  pea 0
  tya
  lsr a
  dec a
  dec a
  pha
  txa
  lsr a
  inc a
  inc a
  pha
  NEW Palette.rotate.CLS.PTR objPalRotate
  pla
  pla
  pla
  pla

_title_screen.noPalRotate:
  lda.w #SAMPLE.0.SHURIKEN
  CALL Spc.SpcPlaySoundEffect.MTD objSpc

  NEW Sprite.super.CLS.PTR objSuper 0 0

  ;--- Menu system ---
  .def menu.idleStart this._tmp+6
  .def menu.state  this._tmp+8
  .def menu.cursor this._tmp+10
  .def menu.param  this._tmp+12
  .def menu.target this._tmp+14

  ;initialize menu state
  stz.b menu.state
  stz.b menu.cursor
  lda #1
  sta.b menu.param
  lda.w FrameCounter
  sta.b menu.idleStart
  jsr _title_screen.drawMenu

_title_screen.menuLoop:
  jsr SavePC

  ;check idle timeout: 1 minute (3600 frames at 60fps)
  lda.w FrameCounter
  sec
  sbc.b menu.idleStart
  cmp #3600
  bcc _title_screen.notIdle
    jmp _title_screen.idleAttract
_title_screen.notIdle:

_title_screen.menuInput:
  ;read trigger input
  ldx #INPUT.DEVICE.ID.0
  jsr core.input.get.trigger
  tax  ;plp in get.trigger restores caller Z flag; tax sets Z from A
  beq +
    sta.b currentLevel
    ;reset idle timer on any input
    lda.w FrameCounter
    sta.b menu.idleStart
    bra _title_screen.handleInput
+ rts

_title_screen.handleInput:
  ;--- SELECT button: insert coin ---
  lda.b currentLevel
  and.w #JOY_BUTTON_SELECT
  beq _title_screen.noSelect
    lda.w GLOBAL.credits
    cmp #99
    bcs _title_screen.noSelect
      inc a
      sta.w GLOBAL.credits
    lda.w #SAMPLE.0.OK
    CALL Spc.SpcPlaySoundEffect.MTD objSpc
    jsr _title_screen.drawMenu
    rts
_title_screen.noSelect:

  ;--- B button: back navigation ---
  lda.b currentLevel
  and.w #JOY_BUTTON_B
  beq _title_screen.noB
    lda.b menu.state
    beq _title_screen.bDone         ;no back from main menu
    cmp #1
    beq _title_screen.backToMain
    ;states 2,3: back to options
    lda #1
    sta.b menu.state
    stz.b menu.cursor
    lda.w #SAMPLE.0.OK
    CALL Spc.SpcPlaySoundEffect.MTD objSpc
    jsr _title_screen.drawMenu
_title_screen.bDone:
    rts

_title_screen.backToMain:
    stz.b menu.state
    stz.b menu.cursor
    lda.w #SAMPLE.0.OK
    CALL Spc.SpcPlaySoundEffect.MTD objSpc
    jsr _title_screen.drawMenu
    rts

_title_screen.noB:
  ;dispatch cursor input (states 0,1) vs param input (states 2,3)
  lda.b menu.state
  cmp #2
  bcc _title_screen.cursorSection
    jmp _title_screen.paramSection

  ;=== CURSOR INPUT (states 0,1) ===
_title_screen.cursorSection:
  ;--- UP ---
  lda.b currentLevel
  and.w #JOY_DIR_UP
  beq _title_screen.noUp
    lda.b menu.cursor
    beq _title_screen.upWrap
      dec a
      bra _title_screen.cursorMoved
_title_screen.upWrap:
    lda #2                        ;options: 3 items (0-2)
    ldx.b menu.state
    bne +
      lda #1                      ;main menu: 2 items (0-1)
+   bra _title_screen.cursorMoved

_title_screen.noUp:
  ;--- DOWN ---
  lda.b currentLevel
  and.w #JOY_DIR_DOWN
  beq _title_screen.noDown
    lda.b menu.cursor
    ldx.b menu.state
    beq _title_screen.downMainMax
      cmp #2                      ;options: wrap at 2
      bra _title_screen.downCheckWrap
_title_screen.downMainMax:
      cmp #1                      ;main menu: wrap at 1
_title_screen.downCheckWrap:
    bcc _title_screen.downNoWrap
      lda #$ffff
_title_screen.downNoWrap:
    inc a
_title_screen.cursorMoved:
    sta.b menu.cursor
    lda.w #SAMPLE.0.OK
    CALL Spc.SpcPlaySoundEffect.MTD objSpc
    jsr _title_screen.drawMenu
    rts

_title_screen.noDown:
  ;--- A/START: select item ---
  lda.b currentLevel
  and.w #(JOY_BUTTON_A | JOY_BUTTON_START)
  beq _title_screen.cursorDone

  lda.b menu.state
  bne _title_screen.optionsSelect

  ;main menu selection
  lda.b menu.cursor
  cmp #1
  bne _title_screen.checkGameModes
    jmp _title_screen.selectOptions
_title_screen.checkGameModes:
  ;game mode (cursor 0) needs credits
  lda.w GLOBAL.credits
  bne _title_screen.modeHasCredits
    jsr _title_screen.drawMenu
    rts
_title_screen.modeHasCredits:
  dec a
  sta.w GLOBAL.credits
  lda.w #SAMPLE.0.SAVEME
  CALL Spc.SpcPlaySoundEffect.MTD objSpc

  ;cursor 0 = ARCADE MODE (only game mode)
_title_screen.selectArcadeMode:
  stz.w GLOBAL.gameMode
  sep #$20
  lda #1
  sta.w GLOBAL.currentScene
  rep #$20
  lda.w #level1
  sta.b menu.target
  jmp _title_screen.startTransitionFade

_title_screen.selectOptions:
  lda #1
  sta.b menu.state
  stz.b menu.cursor
  lda.w #SAMPLE.0.OK
  CALL Spc.SpcPlaySoundEffect.MTD objSpc
  jsr _title_screen.drawMenu
_title_screen.cursorDone:
  rts

_title_screen.optionsSelect:
  lda.b menu.cursor
  beq _title_screen.selectHighScores
  cmp #1
  beq _title_screen.selectSoundTest
  cmp #2
  beq _title_screen.selectLevelSelect
  rts

_title_screen.selectHighScores:
  lda.w #hall_of_fame
  sta.b menu.target
  jmp _title_screen.startTransition

_title_screen.idleAttract:
  stz.w GLOBAL.credits
  ;kill existing Pause singleton so buttons don't clash in attract mode
  lda.w #OBJID.Pause
  jsr abstract.Iterator.kill.byId
  lda.w #hall_of_fame
  sta.b menu.target
  jmp _title_screen.startTransitionNoPause

_title_screen.selectSoundTest:
  lda #2
  sta.b menu.state
  stz.b menu.param
  lda.w #SAMPLE.0.OK
  CALL Spc.SpcPlaySoundEffect.MTD objSpc
  jsr _title_screen.drawMenu
  rts

_title_screen.selectLevelSelect:
  lda #3
  sta.b menu.state
  lda #1
  sta.b menu.param
  lda.w #SAMPLE.0.OK
  CALL Spc.SpcPlaySoundEffect.MTD objSpc
  jsr _title_screen.drawMenu
  rts

  ;=== PARAM INPUT (states 2,3) ===
_title_screen.paramSection:
  ;--- LEFT ---
  lda.b currentLevel
  and.w #JOY_DIR_LEFT
  beq _title_screen.noLeft
    lda.b menu.state
    cmp #3
    beq _title_screen.leftLevel
    ;sound test: decrement 0-6
    lda.b menu.param
    beq _title_screen.leftSoundWrap
      dec a
      bra _title_screen.paramMoved
_title_screen.leftSoundWrap:
    lda #6
    bra _title_screen.paramMoved

_title_screen.leftLevel:
    lda.b menu.param
    cmp #2
    bcs _title_screen.leftLevelOk
      lda #9		;wrap: 1 -> 8
_title_screen.leftLevelOk:
    dec a
    bra _title_screen.paramMoved

_title_screen.noLeft:
  ;--- RIGHT ---
  lda.b currentLevel
  and.w #JOY_DIR_RIGHT
  beq _title_screen.noRight
    lda.b menu.state
    cmp #3
    beq _title_screen.rightLevel
    ;sound test: increment 0-6
    lda.b menu.param
    cmp #6
    bcc _title_screen.rightSoundOk
      lda #$ffff
_title_screen.rightSoundOk:
    inc a
    bra _title_screen.paramMoved

_title_screen.rightLevel:
    lda.b menu.param
    cmp #8
    bcc _title_screen.rightLevelOk
      lda #0		;wrap: 8 -> 1
_title_screen.rightLevelOk:
    inc a
_title_screen.paramMoved:
    sta.b menu.param
    lda.w #SAMPLE.0.OK
    CALL Spc.SpcPlaySoundEffect.MTD objSpc
    jsr _title_screen.drawMenu
    rts

_title_screen.noRight:
  ;--- A: play sample or start level ---
  lda.b currentLevel
  and.w #(JOY_BUTTON_A | JOY_BUTTON_START)
  beq _title_screen.paramDone

  lda.b menu.state
  cmp #3
  beq _title_screen.levelSelectGo
  ;sound test: play selected sample
  lda.b menu.param
  CALL Spc.SpcPlaySoundEffect.MTD objSpc
_title_screen.paramDone:
  rts

_title_screen.levelSelectGo:
  sep #$20
  lda.b menu.param
  sta.w GLOBAL.currentScene
  rep #$20
  lda.b menu.param
  dec a
  asl a
  tax
  lda.l _title_screen.sceneTable,x
  sta.b menu.target
  ;fall through to startTransition

;--- Start transition: confirm sound + fade to black ---
_title_screen.startTransition:
  lda.w #SAMPLE.0.TECHNIQUE
  CALL Spc.SpcPlaySoundEffect.MTD objSpc
_title_screen.startTransitionFade:
  NEW Pause.CLS.PTR oopCreateNoPtr
_title_screen.startTransitionNoPause:
  lda #BRIGHTNESS.NONE
  CALL Brightness.fadeTo.MTD objBrightness

  jsr SavePC
  CALL Brightness.isDone.MTD objBrightness
  bcs +
    rts
+

;--- Cleanup and launch target script ---
_title_screen.doCleanup:
  ;Stop HDMA hardware and flush DMA queue before killing objects
  ;(prevents stale DMA entries from firing after objects are destroyed)
  jsr core.dma.resetHardware

  CALL Sprite.super.kill.MTD objSuper
  jsr core.oam.clearTable
  CALL Background.generic.kill.MTD objBackground
  CALL Background.generic.kill.MTD objLogo
  CALL Background.textlayer.8x8.kill.MTD objText
  ldx #objPalRotate
  jsr oop.object.exists
  bcc _title_screen.noPalKill
    CALL Palette.rotate.kill.MTD objPalRotate
_title_screen.noPalKill:
  jsr core.vram.init
  lda.w #OBJECT.PROPERTIES.isHdma
  jsr abstract.Iterator.kill.byProperties
  ldx irq.buffer.x
  ldy irq.buffer.y
  jsr core.irq.position.set
  jsr core.cgram.clear
  lda.b menu.target
  pha
  NEW Script.CLS.PTR oopCreateNoPtr
  pla
  DIE

;--- Draw the current menu screen ---
_title_screen.drawMenu:
  CALL Background.textlayer.8x8.clear.MTD objText
  lda #T_title.PTR
  CALL Background.textlayer.8x8.print.MTD objText

  ;select menu string based on state
  lda.b menu.state
  beq _title_screen.drawMain
  cmp #1
  beq _title_screen.drawOptions
  cmp #2
  beq _title_screen.drawSoundTest

  ;state 3: scene select — compute scene name LUT index
  lda.b menu.param
  dec a
  and #$00FF
  clc
  adc #T_sceneName.1.PTR
  sta.w GLOBAL.pauseSceneNameIdx

  lda #T_menu_levelselect.PTR
  pei (menu.param)
  CALL Background.textlayer.8x8.print.MTD objText
  pla
  bra _title_screen.drawFlush

_title_screen.drawMain:
  lda #T_menu_main_credits.PTR
  CALL Background.textlayer.8x8.print.MTD objText
  bra _title_screen.drawCursor

_title_screen.drawOptions:
  lda #T_menu_options.PTR
  CALL Background.textlayer.8x8.print.MTD objText
  bra _title_screen.drawCursor

_title_screen.drawSoundTest:
  lda #T_menu_soundtest.PTR
  pei (menu.param)
  CALL Background.textlayer.8x8.print.MTD objText
  pla
  bra _title_screen.drawFlush

_title_screen.drawCursor:
  ;write '>' at cursor position in string buffer
  ;offset = $286 + cursor * 32
  lda.b menu.cursor
  asl a
  asl a
  asl a
  asl a
  asl a
  clc
  adc.w #$286
  tax
  sep #$20
  lda #$3E
  sta.w GLOBAL.CORE.STRING.buffer,x
  rep #$20

_title_screen.drawFlush:
  CALL Background.textlayer.8x8.flush.MTD objText
  rts

;--- Scene lookup table (8 scenes, each launches the _start_alive chapter) ---
_title_screen.sceneTable:
  .dw csno_start_alive		;1  casino_heist
  .dw gtwy_start_alive		;2  the_getaway
  .dw roof_start_alive		;3  rooftops
  .dw hway_start_alive		;4  highway
  .dw cstl_start_alive		;5  the_castle_battle
  .dw fnle_start_alive		;6  finale
  .dw fn2_start_alive		;7  finale_ii
  .dw endg_start_alive		;8  ending

