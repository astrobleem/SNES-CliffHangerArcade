/**
* Dirk's downward brake/duck prompt (D-pad down).
* RoadBlasters-era name retained for compatibility; prefer the down
* direction standard over this deprecated event label.
*/
.include "src/object/event/Event.brake.h"
.section "Event.brake"

  METHOD init
  rep #$31

  jsr Event.template.initCommon

  lda event.endFrame
  NEW Feet_icon.CLS.PTR this.sprite 112 80
  lda event.endFrame
  CALL Feet_icon.reset.MTD this.sprite 112 80
  
  NEW Spc.CLS.PTR this.audio
  lda.w #SAMPLE.0.BRAKE
  CALL Spc.SpcPlaySoundEffect.MTD this.audio

  rts

  METHOD play
  rep #$31

  jsr Event.template.waitTimeline
  bcc _brake_done

  ;kill self if player pressed appropriate button
  ldx #INPUT.DEVICE.ID.0
  jsr core.input.get.press
  and.w #JOY_DIR_DOWN
  bne _brake_correctPress
  jmp _brake_done
_brake_correctPress:

      jsr core.input.get.trigger
      and.w #JOY_DIR_DOWN
      beq _brake_score_default
        lda event.age
        cmp #EVENT.BONUS.EXTRA.TIMEOUT
        bcs _brake_score_default
          lda #PLAYER.BONUS.EXTRA
          bra _brake_spawn_score
_brake_score_default:
      lda #PLAYER.BONUS.DEFAULT
_brake_spawn_score:
        NEW Sprite.score.CLS.PTR oopCreateNoPtr 112 80
    jsr abstract.Event.triggerResult
        rts

_brake_done:
  rts

  METHOD kill
  jmp Event.template.kill

  CLASS Event.brake

.ends
	
